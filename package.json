{
  "name": "@gundo/ui",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./charts": "./src/charts/index.ts",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --project=finance --project=radar --project=jp-assistant --project=engine",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "gallery:dev": "vite --config gallery/vite.config.ts",
    "gallery:build": "vite build --config gallery/vite.config.ts",
    "gallery:preview": "vite preview --config gallery/vite.config.ts"
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.11.1",
    "jsdom": "^28.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.24.1"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "dependencies": {
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0"
  }
}
