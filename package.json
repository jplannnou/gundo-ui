{
  "name": "@jplannnou/gundo-ui",
  "version": "1.29.3",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "import": "./dist/charts/index.js"
    },
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsc && node scripts/fix-esm-imports.js",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test --project=finance --project=radar --project=jp-assistant --project=engine",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:a11y": "playwright test --project=a11y",
    "test:browser": "vitest run --config vitest.config.browser.ts",
    "gallery:dev": "vite --config gallery/vite.config.ts",
    "gallery:build": "vite build --config gallery/vite.config.ts",
    "gallery:preview": "vite preview --config gallery/vite.config.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jplannnou/gundo-ui.git"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "recharts": "^3.0.0",
    "i18next": "^25.0.0",
    "react-i18next": "^15.0.0 || ^16.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^3.0.6"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    },
    "i18next": {
      "optional": true
    },
    "react-i18next": {
      "optional": true
    },
    "i18next-browser-languagedetector": {
      "optional": true
    },
    "i18next-http-backend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.1.9",
    "axe-core": "^4.12.1",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "jsdom": "^28.1.0",
    "react-i18next": "^16.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.24.1",
      "lodash-es": ">=4.18.0",
      "picomatch": ">=4.0.4"
    }
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0"
  },
  "optionalDependencies": {
    "@jplannnou/eslint-config": "^1.0.3"
  }
}
